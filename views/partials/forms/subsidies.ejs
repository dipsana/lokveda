<label>
    Applicant Name:
    <input type="text" name="applicantName" required>
</label>

<label>
    Aadhaar Number:
    <input type="text" name="aadhaarNumber" maxlength="12" required>
</label>

<label>
    Subsidy Type:
    <select name="subsidyType" required>
        <option value="">--Select--</option>
        <option value="agriculture">Agricultural Subsidy</option>
        <option value="education">Education Subsidy</option>
        <option value="housing">Housing Subsidy</option>
    </select>
</label>

<label>
    Application Number (if tracking):
    <input type="text" name="trackingId">
</label>

<label>
    Upload Relevant Documents:
     <!-- multiple -->
    <input type="file" name="documents">
</label>