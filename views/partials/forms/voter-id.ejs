<label>
    Full Name:
    <input type="text" name="fullName" required>
</label>

<label>
    Date of Birth:
    <input type="date" name="dob" required>
</label>

<label>
    Address:
    <textarea name="address" rows="4" required></textarea>
</label>

<label>
    Application Number (for tracking):
    <input type="text" name="applicationNumber">
</label>